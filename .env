OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
EMBEDDING_MODEL=nomic-embed-text
USE_SENTENCE_TRANSFORMERS=false
USE_LLM_SUBTOPICS=true
CHAPTER_MAX_CHARS=12000
SUBTOPIC_MAX_CHARS=12000
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4
RETRIEVAL_CANDIDATE_K=24
TEMPERATURE=0.2
EMBEDDING_BATCH_SIZE=64
PDF_CACHE_DIR=cache/pdfs
INDEX_DIR=cache/index
NCERT_CATALOG_PATH=database/ncert_catalog.json
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=["http://localhost:5173"]
